<?xml version="1.0" encoding="utf-8"?>
<!-- SPDX-License-Identifier: Apache-2.0 -->
<!--
  Restore sources for the EXTERNAL consumer sample. <clear /> drops any inherited
  sources (including the repo-root nuget.config) so this directory restores exactly
  from nuget.org plus the repo's local feed where the binding is packed.
-->
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
    <add key="local-feed" value="../../artifacts/feed" />
  </packageSources>
</configuration>

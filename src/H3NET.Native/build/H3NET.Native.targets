<!--
  PACKAGED consumer target. Shipped at buildTransitive/H3NET.Native.targets in the
  nupkg, so it runs in both direct and transitive PackageReference consumer builds.

  Why this exists: the SDK auto-resolves runtimes/{rid}/native/ assets only for
  RID-specific (self-contained / RID-targeted) builds. Framework-dependent,
  RID-less consumer builds do NOT get the native lib copied next to their output
  assembly, so the loader cannot find libh3 at run time. This target mirrors the
  local-dev eng/ target but resolves paths against the INSTALLED package layout:
  once restored, this file is at <pkg>/buildTransitive/ and the native assets are at
  <pkg>/runtimes/{rid}/native/, i.e. $(MSBuildThisFileDirectory)../runtimes/.

  $(NETCoreSdkRuntimeIdentifier) is the host RID. Idempotent via SkipUnchangedFiles.
-->
<Project>

  <Target Name="_H3NETCopyNativeForHost"
          AfterTargets="Build"
          BeforeTargets="_CopyFilesMarkedCopyLocal"
          Condition="'$(NETCoreSdkRuntimeIdentifier)' != '' And Exists('$(MSBuildThisFileDirectory)../runtimes/$(NETCoreSdkRuntimeIdentifier)/native/')">
    <ItemGroup>
      <_H3NETHostNative Include="$(MSBuildThisFileDirectory)../runtimes/$(NETCoreSdkRuntimeIdentifier)/native/libh3.*" />
    </ItemGroup>
    <Copy SourceFiles="@(_H3NETHostNative)"
          DestinationFolder="$(OutDir)"
          SkipUnchangedFiles="true"
          Condition="'@(_H3NETHostNative)' != '' And '$(OutDir)' != ''" />
  </Target>

</Project>

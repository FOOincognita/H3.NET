{
  "metadata": [
    {
      "src": [
        {
          "src": "src/H3.NET.Native",
          "files": [
            "H3.NET.Native.csproj"
          ]
        }
      ],
      "dest": "api",
      "outputFormat": "mref",
      "properties": {
        "TargetFramework": "net10.0"
      },
      "namespaceLayout": "nested",
      "memberLayout": "samePage",
      "filter": "filterConfig.yml"
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/**/toc.yml"
        ]
      },
      {
        "files": [
          "index.md",
          "toc.yml"
        ],
        "src": "docs"
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml"
        ],
        "src": "docs"
      }
    ],
    "resource": [
      {
        "files": [
          "articles/images/**"
        ],
        "src": "docs"
      }
    ],
    "globalMetadata": {
      "_appName": "H3.NET.Native",
      "_appTitle": "H3.NET.Native",
      "_enableSearch": true,
      "_disableContribution": false,
      "_gitContribute": {
        "repo": "https://github.com/FOOincognita/H3.NET.Native",
        "branch": "main"
      }
    },
    "dest": "_site",
    "template": [
      "default",
      "modern"
    ]
  }
}
